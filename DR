#### A. Archival & WORM (Write Once Read Many)
This function configures a GCS bucket with a WORM policy to prevent data from being deleted or modified for a specific retention period.

```go
// pkg/storage/gcsarchival.go
package storage

import (
	"context"
	"fmt"
	"time"

	"cloud.google.com/go/storage"
)

// EnableWORM applies a retention policy and locks the bucket.
func EnableWORM(projectID, bucketName string, retentionDays int) error {
	ctx := context.Background()
	client, err := storage.NewClient(ctx)
	if err != nil {
		return fmt.Errorf("storage.NewClient: %w", err)
	}
	defer client.Close()

	bucket := client.Bucket(bucketName)

	// 1. Set the retention policy
	retentionPeriod := time.Duration(retentionDays) * 24 * time.Hour
	attrsToUpdate := storage.BucketAttrsToUpdate{
		RetentionPolicy: &storage.RetentionPolicy{
			RetentionPeriod: retentionPeriod,
		},
	}
	if _, err := bucket.Update(ctx, attrsToUpdate); err != nil {
		return fmt.Errorf("Bucket(%q).Update retention: %w", bucketName, err)
	}

	// 2. Lock the bucket (WARNING: This is irreversible until the policy expires)
	if err := bucket.LockRetentionPolicy(ctx); err != nil {
		return fmt.Errorf("Bucket(%q).LockRetentionPolicy: %w", bucketName, err)
	}

	fmt.Printf("WORM enabled and locked for %s for %d days.\n", bucketName, retentionDays)
	return nil
}
```

#### B. Data Anonymization (Privacy Rules)
This uses Google Cloud DLP to take sensitive text (e.g., PII extracted during a purge/archival job) and mask it before moving it to cold storage.

```go
// pkg/privacy/anonymize.go
package privacy

import (
	"context"
	"fmt"

	dlp "cloud.google.com/go/dlp/apiv2"
	"cloud.google.com/go/dlp/apiv2/dlppb"
)

// MaskPII replaces sensitive data (like emails/phone numbers) with asterisks.
func MaskPII(projectID, input string) (string, error) {
	ctx := context.Background()
	client, err := dlp.NewClient(ctx)
	if err != nil {
		return "", fmt.Errorf("dlp.NewClient: %w", err)
	}
	defer client.Close()

	req := &dlppb.DeidentifyContentRequest{
		Parent: fmt.Sprintf("projects/%s/locations/global", projectID),
		DeidentifyConfig: &dlppb.DeidentifyConfig{
			Transformation: &dlppb.DeidentifyConfig_InfoTypeTransformations{
				InfoTypeTransformations: &dlppb.InfoTypeTransformations{
					Transformations: []*dlppb.InfoTypeTransformations_InfoTypeTransformation{
						{
							// Mask with asterisks
							PrimitiveTransformation: &dlppb.PrimitiveTransformation{
								Transformation: &dlppb.PrimitiveTransformation_CharacterMaskConfig{
									CharacterMaskConfig: &dlppb.CharacterMaskConfig{
										MaskingCharacter: "*",
									},
								},
							},
						},
					},
				},
			},
		},
		Item: &dlppb.ContentItem{
			DataItem: &dlppb.ContentItem_Value{
				Value: input,
			},
		},
	}

	resp, err := client.DeidentifyContent(ctx, req)
	if err != nil {
		return "", fmt.Errorf("DeidentifyContent: %w", err)
	}

	return resp.GetItem().GetValue(), nil
}
```

#### C. Database DR (Triggering On-Demand Backups)
While automated backups handle RPO, you often need to trigger a manual backup before a purge job or during a DR game-day drill.

```go
// pkg/database/sqldr.go
package database

import (
	"context"
	"fmt"
	"time"

	"google.golang.org/api/sqladmin/v1beta4"
)

// TriggerBackup initiates an on-demand backup for a Cloud SQL instance.
func TriggerBackup(projectID, instanceName string) error {
	ctx := context.Background()
	sqlService, err := sqladmin.NewService(ctx)
	if err != nil {
		return fmt.Errorf("sqladmin.NewService: %w", err)
	}

	description := fmt.Sprintf("On-demand DR backup - %s", time.Now().Format(time.RFC3339))
	
	runReq := &sqladmin.BackupRun{
		Description: description,
	}

	op, err := sqlService.BackupRuns.Insert(projectID, instanceName, runReq).Context(ctx).Do()
	if err != nil {
		return fmt.Errorf("BackupRuns.Insert: %w", err)
	}

	fmt.Printf("Backup triggered successfully. Operation ID: %s\n", op.Name)
	return nil
}
```

### 4. Tying it Together (The Orchestrator)

You would then build out your `main.go` using a CLI framework like `cobra` to allow your operations team or CI/CD pipelines to run these as scheduled jobs.

```go
// main.go
package main

import (
	"log"
	"github.com/yourorg/data-lifecycle-dr/pkg/database"
	"github.com/yourorg/data-lifecycle-dr/pkg/privacy"
)

func main() {
	projectID := "my-gcp-project"
	
	// Example 1: Run a DR backup drill
	log.Println("Starting DR Backup Drill...")
	if err := database.TriggerBackup(projectID, "primary-db-instance"); err != nil {
		log.Fatalf("DR Drill failed: %v", err)
	}

	// Example 2: Anonymize data before archival
	rawData := "Contact the user at jane.doe@example.com or 555-0198."
	safeData, err := privacy.MaskPII(projectID, rawData)
	if err != nil {
		log.Fatalf("Anonymization failed: %v", err)
	}
	log.Printf("Anonymized output: %s", safeData)
}
```

