### 1. Monetary Calculations & Currency
We use `shopspring/decimal` to avoid floating-point errors (like $0.1 + 0.2 \neq 0.3$).

```go
package shared

import (
	"fmt"
	"github.com/shopspring/decimal"
)

// Money represents a value and its currency
type Money struct {
	Amount   decimal.Decimal
	Currency string
}

func NewMoney(amount float64, currency string) Money {
	return Money{
		Amount:   decimal.NewFromFloat(amount),
		Currency: currency,
	}
}

// Add performs safe addition and ensures currency parity
func (m Money) Add(other Money) (Money, error) {
	if m.Currency != other.Currency {
		return Money{}, fmt.Errorf("currency mismatch: %s vs %s", m.Currency, other.Currency)
	}
	return Money{
		Amount:   m.Amount.Add(other.Amount),
		Currency: m.Currency,
	}, nil
}
```

